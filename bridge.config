# =====================================================
#               SINGLE LANE BRIDGE SIMULATION
# =====================================================
# Curso: Principios de Sistemas Operativos
# Proyecto: Narrow Bridge Problem
# =====================================================


# =====================================================
#               GLOBAL PARAMETERS
# =====================================================

# Length of the bridge in meters
bridge_length = 100

# Total simulation time in seconds
simulation_time = 60

# Available modes:
# CARNAGE     -> First-come / same direction allowed
# SEMAPHORE   -> Traffic lights alternating by time
# OFFICER     -> K vehicles per side

mode=CARNAGE


# =====================================================
#               EAST SIDE PARAMETERS
# =====================================================

# Mean arrival time (seconds) for exponential distribution
east_arrival_mean = 2.5

# Speed range in km/h
east_speed_min = 40
east_speed_max = 60

# Percentage of vehicles that are ambulances (0-100)
east_ambulance_percentage = 10

# Duration of green light (seconds) - used in SEMAPHORE mode
east_green_time = 5

# Number of consecutive vehicles allowed - used in OFFICER mode
east_k_value = 3


# =====================================================
#               WEST SIDE PARAMETERS
# =====================================================

# Mean arrival time (seconds) for exponential distribution
west_arrival_mean = 3.0

# Speed range in km/h
west_speed_min = 35
west_speed_max = 55

# Percentage of vehicles that are ambulances (0-100)
west_ambulance_percentage = 15

# Duration of green light (seconds) - used in SEMAPHORE mode
west_green_time = 4

# Number of consecutive vehicles allowed - used in OFFICER mode
west_k_value = 2